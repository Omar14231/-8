local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local UI_NAME = "DeltaGodMode_Final"

-- [ وظيفة التنظيف الكامل ] --
local function FullCleanUp()
    if _G.GodLoop then _G.GodLoop:Disconnect(); _G.GodLoop = nil end
    local Char = LocalPlayer.Character
    if Char and Char:FindFirstChild("HumanoidRootPart") and _G.CurrentFakeChar then
        local FakeHRP = _G.CurrentFakeChar:FindFirstChild("HumanoidRootPart")
        if FakeHRP then
            Char.HumanoidRootPart.CFrame = FakeHRP.CFrame
            Char.HumanoidRootPart.Velocity = FakeHRP.Velocity 
        end
        for _, v in pairs(Char:GetDescendants()) do
            if v:IsA("BasePart") then v.Transparency = 0; v.CanCollide = true
            elseif v:IsA("Decal") then v.Transparency = 0 end
        end
        if Char:FindFirstChild("Humanoid") then Camera.CameraSubject = Char.Humanoid end
    end
    if _G.CurrentFakeChar then _G.CurrentFakeChar:Destroy(); _G.CurrentFakeChar = nil end
    _G.GodModeActive = false
end

if CoreGui:FindFirstChild(UI_NAME) or _G.GodModeActive then
    FullCleanUp()
    if CoreGui:FindFirstChild(UI_NAME) then CoreGui[UI_NAME]:Destroy() end
    task.wait(0.1)
end

local GodMode = false
local FakeChar = nil
local FIXED_HEIGHT = -2.75 
local OFFSET_DISTANCE = 4 

local ScreenGui = Instance.new("ScreenGui", CoreGui)
ScreenGui.Name = UI_NAME

-- [ واجهة التحكم الرئيسية - تظهر فوراً ] --
local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 110, 0, 50) 
MainFrame.Position = UDim2.new(0.9, -110, 0.2, 0) 
MainFrame.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
MainFrame.Visible = true -- جعلناها مرئية مباشرة
MainFrame.Active = true
MainFrame.Draggable = true 

local MainStroke = Instance.new("UIStroke", MainFrame)
MainStroke.Thickness = 3

-- [ زر الحالة ] --
local ToggleBtn = Instance.new("TextButton", MainFrame)
ToggleBtn.Size = UDim2.new(1, 0, 1, 0)
ToggleBtn.BackgroundTransparency = 1
ToggleBtn.Text = "STATUS: OFF\nv1.0 [Q]"
ToggleBtn.TextColor3 = Color3.fromRGB(180, 180, 180)
ToggleBtn.Font = Enum.Font.GothamBold

-- [ تأثير الدوران اللوني ] --
RunService.RenderStepped:Connect(function()
    local hue = (tick() % 4) / 4
    local rainbowColor = Color3.fromHSV(hue, 0.7, 1)
    MainStroke.Color = rainbowColor
    if GodMode then ToggleBtn.TextColor3 = rainbowColor end
end)

-- [ منطق الاختفاء ] --
local function setProperties(char, bool)
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("BasePart") then
            v.Transparency = bool and 1 or 0
            v.CanCollide = not bool
        elseif v:IsA("Decal") then
            v.Transparency = bool and 1 or 0
        end
    end
end

-- [ تفعيل وإلغاء الـ God Mode ] --
local function ToggleGodMode()
    GodMode = not GodMode
    _G.GodModeActive = GodMode
    local Char = LocalPlayer.Character
    if not Char or not Char:FindFirstChild("HumanoidRootPart") then return end

    if GodMode then
        ToggleBtn.Text = "STATUS: ON\nv1.0 [Q]"
        Char.Archivable = true
        FakeChar = Char:Clone()
        _G.CurrentFakeChar = FakeChar
        FakeChar.Parent = workspace
        setProperties(Char, true)
        Camera.CameraSubject = FakeChar.Humanoid

        _G.GodLoop = RunService.Heartbeat:Connect(function()
            if GodMode and FakeChar and Char:FindFirstChild("HumanoidRootPart") then
                local HRP = Char.HumanoidRootPart
                local fHRP = FakeChar.HumanoidRootPart
                FakeChar.Humanoid:Move(Char.Humanoid.MoveDirection, false)
                if Char.Humanoid.Jump then FakeChar.Humanoid.Jump = true end
                
                HRP.Velocity = fHRP.Velocity 
                HRP.CFrame = CFrame.new(fHRP.Position.X + OFFSET_DISTANCE, FIXED_HEIGHT, fHRP.Position.Z)
            end
        end)
    else
        ToggleBtn.Text = "STATUS: OFF\nv1.0 [Q]"
        FullCleanUp()
    end
end

ToggleBtn.MouseButton1Click:Connect(ToggleGodMode)

-- اختصار الكيبورد للحاسوب (اختياري)
UserInputService.InputBegan:Connect(function(input, processed)
    if not processed and input.KeyCode == Enum.KeyCode.Q then
        if MainFrame.Visible then ToggleGodMode() end
    end
end)
