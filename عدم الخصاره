-- [ منطق الاختفاء ] --
local function setProperties(char, bool)
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("BasePart") then
            v.Transparency = bool and 1 or 0
            v.CanCollide = not bool
        elseif v:IsA("Decal") then
            v.Transparency = bool and 1 or 0
        end
    end
end

-- [ تفعيل وإلغاء الـ God Mode ] --
local function ToggleGodMode()
    GodMode = not GodMode
    _G.GodModeActive = GodMode
    local Char = LocalPlayer.Character
    if not Char or not Char:FindFirstChild("HumanoidRootPart") then return end

    if GodMode then
        ToggleBtn.Text = "STATUS: ON\nv1.0 [Q]"
        Char.Archivable = true
        FakeChar = Char:Clone()
        _G.CurrentFakeChar = FakeChar
        FakeChar.Parent = workspace
        setProperties(Char, true)
        Camera.CameraSubject = FakeChar.Humanoid

        _G.GodLoop = RunService.Heartbeat:Connect(function()
            if GodMode and FakeChar and Char:FindFirstChild("HumanoidRootPart") then
                local HRP = Char.HumanoidRootPart
                local fHRP = FakeChar.HumanoidRootPart
                FakeChar.Humanoid:Move(Char.Humanoid.MoveDirection, false)
                if Char.Humanoid.Jump then FakeChar.Humanoid.Jump = true end
                
                HRP.Velocity = fHRP.Velocity 
                HRP.CFrame = CFrame.new(fHRP.Position.X + OFFSET_DISTANCE, FIXED_HEIGHT, fHRP.Position.Z)
            end
        end)
    else
        ToggleBtn.Text = "STATUS: OFF\nv1.0 [Q]"
        FullCleanUp()
    end
end

ToggleBtn.MouseButton1Click:Connect(ToggleGodMode)

UserInputService.InputBegan:Connect(function(input, processed)
    if not processed and input.KeyCode == Enum.KeyCode.Q then
        if MainFrame.Visible then ToggleGodMode() end
    end
end)

