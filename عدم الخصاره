local function setProperties(char, bool)
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("BasePart") then
            v.Transparency = bool and 1 or 0
            v.CanCollide = not bool
        elseif v:IsA("Decal") then
            v.Transparency = bool and 1 or 0
        end
    end
end

local function CleanUp()
    GodMode = false
    ToggleBtn.Text = "STATUS: OFF\n" .. VERSION_TEXT .. " [Q]"
    if _G.GodLoop then _G.GodLoop:Disconnect() end
    
    local Char = LocalPlayer.Character
    if Char and Char:FindFirstChild("HumanoidRootPart") and FakeChar then
        Char.HumanoidRootPart.CFrame = FakeChar.HumanoidRootPart.CFrame
        Char.HumanoidRootPart.Velocity = FakeChar.HumanoidRootPart.Velocity
        setProperties(Char, false)
        if Char:FindFirstChild("Humanoid") then Camera.CameraSubject = Char.Humanoid end
    end
    if FakeChar then FakeChar:Destroy(); FakeChar = nil end
end

local function ToggleGodMode()
    GodMode = not GodMode
    local Char = LocalPlayer.Character
    if not Char or not Char:FindFirstChild("HumanoidRootPart") then return end
    local HRP = Char.HumanoidRootPart
    local Hum = Char.Humanoid

    if GodMode then
        ToggleBtn.Text = "STATUS: ON\n" .. VERSION_TEXT .. " [Q]"
        Char.Archivable = true
        FakeChar = Char:Clone()
        FakeChar.Parent = workspace
        FakeChar.HumanoidRootPart.CFrame = HRP.CFrame
        setProperties(Char, true)
        Camera.CameraSubject = FakeChar.Humanoid

        _G.GodLoop = RunService.Heartbeat:Connect(function()
            if GodMode and FakeChar and Char:FindFirstChild("HumanoidRootPart") then
                FakeChar.Humanoid:Move(Hum.MoveDirection, false)
                if Hum.Jump then FakeChar.Humanoid.Jump = true end
                
                local fakeHRP = FakeChar.HumanoidRootPart
                local targetPos = fakeHRP.Position
                
                -- نظام الهروب الذكي: إذا نزل الـ Fake لمستوى قريب من الـ Real
                local currentOffset = Vector3.new(0, 0, 0)
                if math.abs(fakeHRP.Position.Y - FIXED_HEIGHT) < 5 then
                    currentOffset = fakeHRP.CFrame.RightVector * OFFSET_DISTANCE
                end
                
                HRP.CFrame = CFrame.new(targetPos.X + currentOffset.X, FIXED_HEIGHT, targetPos.Z + currentOffset.Z)
                HRP.Velocity = Vector3.zero
            end
        end)
    else
        CleanUp()
    end
end

-- Events
ToggleBtn.MouseButton1Click:Connect(ToggleGodMode)

UserInputService.InputBegan:Connect(function(input, processed)
    if not processed and input.KeyCode == Enum.KeyCode.Q then
        if MainFrame.Visible then ToggleGodMode() end
    end
end)

