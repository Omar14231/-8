-- [ وظيفة التنظيف الكامل ] --
local function FullCleanUp()
    if _G.GodLoop then _G.GodLoop:Disconnect(); _G.GodLoop = nil end
    local Char = LocalPlayer.Character
    if Char and Char:FindFirstChild("HumanoidRootPart") and _G.CurrentFakeChar then
        local FakeHRP = _G.CurrentFakeChar:FindFirstChild("HumanoidRootPart")
        if FakeHRP then
            Char.HumanoidRootPart.CFrame = FakeHRP.CFrame
            Char.HumanoidRootPart.Velocity = FakeHRP.Velocity 
        end
        for _, v in pairs(Char:GetDescendants()) do
            if v:IsA("BasePart") then v.Transparency = 0; v.CanCollide = true
            elseif v:IsA("Decal") then v.Transparency = 0 end
        end
        if Char:FindFirstChild("Humanoid") then Camera.CameraSubject = Char.Humanoid end
    end
    if _G.CurrentFakeChar then _G.CurrentFakeChar:Destroy(); _G.CurrentFakeChar = nil end
    _G.GodModeActive = false
end

if CoreGui:FindFirstChild(UI_NAME) or _G.GodModeActive then
    FullCleanUp()
    if CoreGui:FindFirstChild(UI_NAME) then CoreGui[UI_NAME]:Destroy() end
    task.wait(0.1)
end

