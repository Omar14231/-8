local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local GodMode = false
local FakeChar = nil
local fixedY = 0 -- الارتفاع الثابت للحقيقية

-- واجهة الزر (تصميم عصري وقابل للسحب)
local ScreenGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 90, 0, 45) 
MainFrame.Position = UDim2.new(0.9, -90, 0.2, 0) 
MainFrame.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
MainFrame.Active = true
MainFrame.Draggable = true 

local Corner = Instance.new("UICorner", MainFrame)
Corner.CornerRadius = UDim.new(0, 12)

local UIStroke = Instance.new("UIStroke", MainFrame)
UIStroke.Thickness = 3
UIStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

local ToggleBtn = Instance.new("TextButton", MainFrame)
ToggleBtn.Size = UDim2.new(1, 0, 1, 0)
ToggleBtn.BackgroundTransparency = 1
ToggleBtn.Text = "OFF"
ToggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
ToggleBtn.Font = Enum.Font.GothamBold
ToggleBtn.TextSize = 18

-- نظام الألوان (قوس قزح كل 5 ثوانٍ)
RunService.RenderStepped:Connect(function()
    local hue = (tick() % 5) / 5
    local color = Color3.fromHSV(hue, 0.8, 1)
    UIStroke.Color = color
    if GodMode then
        ToggleBtn.TextColor3 = color
    else
        ToggleBtn.TextColor3 = Color3.fromRGB(180, 180, 180)
    end
end)

local function setInvisible(char, bool)
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("BasePart") or v:IsA("Decal") or v:IsA("BoxHandleAdornment") or v:IsA("SelectionBox") then
            v.Transparency = bool and 1 or 0
        end
    end
end

local function CleanUp()
    GodMode = false
    ToggleBtn.Text = "OFF"
    if _G.GodLoop then _G.GodLoop:Disconnect() end
    if FakeChar then FakeChar:Destroy(); FakeChar = nil end
    
    local Char = LocalPlayer.Character
    if Char then
        setInvisible(Char, false)
        local Hum = Char:FindFirstChild("Humanoid")
        if Hum then
            Hum.JumpPower = 50 
            Camera.CameraSubject = Hum
        end
        for _, v in pairs(Char:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = true end
        end
    end
end

ToggleBtn.MouseButton1Click:Connect(function()
    GodMode = not GodMode
    local Char = LocalPlayer.Character
    if not Char or not Char:FindFirstChild("HumanoidRootPart") then return end
    local HRP = Char.HumanoidRootPart
    local Hum = Char.Humanoid

    if GodMode then
        ToggleBtn.Text = "ON"
        
        -- تحديد الارتفاع الثابت (الآن ولمرة واحدة عند التفعيل)
        fixedY = HRP.Position.Y - 5
        
        Char.Archivable = true
        FakeChar = Char:Clone()
        FakeChar.Parent = workspace
        FakeChar.HumanoidRootPart.CFrame = HRP.CFrame
        
        setInvisible(Char, true)
        Hum.JumpPower = 50 
        Camera.CameraSubject = FakeChar.Humanoid

        local deathConn
        deathConn = Hum.Died:Connect(function()
            CleanUp()
            deathConn:Disconnect()
        end)

        _G.GodLoop = RunService.Heartbeat:Connect(function()
            if GodMode and FakeChar and Char:FindFirstChild("HumanoidRootPart") then
                -- مزامنة الحركة
                FakeChar.Humanoid:Move(Hum.MoveDirection, false)
                if Hum.Jump then FakeChar.Humanoid.Jump = true end
                
                local fakePos = FakeChar.HumanoidRootPart.Position
                
                -- الحقيقية تتبع المشي (X, Z) لكن الارتفاع (Y) ثابت تماماً لا يتغير
                HRP.CFrame = CFrame.new(fakePos.X, fixedY, fakePos.Z)
                HRP.Velocity = Vector3.zero
                
                for _, v in pairs(Char:GetDescendants()) do
                    if v:IsA("BasePart") then v.CanCollide = false end
                end
            end
        end)
    else
        CleanUp()
    end
end)
