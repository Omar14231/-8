local function setInvisible(char, bool)
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("BasePart") or v:IsA("Decal") or v:IsA("BoxHandleAdornment") or v:IsA("SelectionBox") then
            v.Transparency = bool and 1 or 0
        end
    end
end

local function CleanUp()
    GodMode = false
    ToggleBtn.Text = "OFF"
    if _G.GodLoop then _G.GodLoop:Disconnect() end
    if FakeChar then FakeChar:Destroy(); FakeChar = nil end
    
    local Char = LocalPlayer.Character
    if Char then
        setInvisible(Char, false)
        local Hum = Char:FindFirstChild("Humanoid")
        if Hum then
            Hum.JumpPower = 50 
            Camera.CameraSubject = Hum
        end
        for _, v in pairs(Char:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = true end
        end
    end
end

